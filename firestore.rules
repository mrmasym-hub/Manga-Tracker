rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: mangas
    // Document ID: auto-generated
    // Fields:
    //   - userId: string (required, immutable) - owner UID
    //   - title: string (required) - manga title
    //   - url: string (required) - source URL
    //   - currentChapter: number (required) - progress
    //   - totalChapters: number (optional) - total count
    //   - lastUpdated: string (optional) - update date
    //   - createdAt: timestamp (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidManga(data) {
      return data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.url is string && data.url.matches("^https?://.*") &&
             data.currentChapter is number && data.currentChapter >= 0 &&
             (!('totalChapters' in data) || data.totalChapters is number) &&
             (!('lastUpdated' in data) || data.lastUpdated is string) &&
             data.createdAt is timestamp;
    }

    match /mangas/{mangaId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidManga(request.resource.data);
      allow update: if isDocOwner() && 
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt &&
                      isValidManga(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
